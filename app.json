{
  "expo": {
    "name": "BookMySession",
    "slug": "bookmysession",
    "version": "1.0.2-alpha",
    "orientation": "portrait",
    "icon": "./assets/images/Logo.png",
    "scheme": "bookmysession",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/Logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#020817"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bookmysession.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Upload profile photos",
        "NSPhotoLibraryUsageDescription": "Select profile photos from gallery"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#020817"
      },
      "package": "com.bookmysession.app",
      "permissions": ["INTERNET", "ACCESS_NETWORK_STATE"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "628add1b-f8b5-4f75-b3c2-3a0d534b31e1"
      }
    },
    "owner": "alokd07"
  }
}
